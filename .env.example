# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# PostgreSQL connection — same DB used by n8n on Zeabur
DATABASE_URL=postgresql://user:password@host:5432/dbname

# iron-session secret — generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars

# Optional: trigger cache revalidation from n8n after each run
REVALIDATE_SECRET=another_random_secret
